# Copiá este archivo a .env y completá los valores.
# (El .env real NUNCA se sube al repo — está en .gitignore.)
#
# ┌────────────────────────────────────────────────────────────────────────────┐
# │ MODO REAL (producción): las variables [CRÍTICA] son OBLIGATORIAS. Si falta  │
# │ cualquiera, la app NO arranca (falla con un mensaje claro). No hay valores  │
# │ por defecto adivinables.                                                    │
# │                                                                             │
# │ MODO DEMO (showcase público): NO necesita ninguna de estas. Alcanza con     │
# │ DEMO_MODE=true. Los pagos son simulados y no hay cuentas reales.            │
# └────────────────────────────────────────────────────────────────────────────┘

# ── Firma de tokens de sesión de staff ───────────────────────────── [CRÍTICA]
# Firma los tokens de admin/encargado/bartender/founder. Si se filtra o es
# adivinable, se pueden FALSIFICAR sesiones de staff. Usá un valor aleatorio
# largo (64 hex). Generá uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# (WOL_SECRET se acepta como alias por compatibilidad, pero usá SESSION_SECRET.)
SESSION_SECRET=

# ── Contraseñas de los founders (equipo WOL) ─────────────────────── [CRÍTICA]
# Login de founder (/wol-hq). Sin estas, el acceso de founder sería adivinable.
FOUNDER_LUCAS_PASS=
FOUNDER_WENCES_PASS=

# ── Mercado Pago (Checkout Pro) ──────────────────────────────────── [CRÍTICA]
# Se obtienen en: https://www.mercadopago.com.ar/developers → Tus integraciones → Credenciales
# Para testear usá credenciales de PRUEBA (TEST-...). En producción, las de la
# cuenta del boliche (APP_USR-...).
#   · MP_ACCESS_TOKEN   — sin él, el endpoint /pay-sim quedaría abierto (pedidos gratis).
#   · MP_WEBHOOK_SECRET — sin él, el webhook no valida la firma x-signature.
MP_ACCESS_TOKEN=TEST-xxxxxxxx
MP_WEBHOOK_SECRET=tu_clave_secreta_del_webhook

# ── Opcionales (no bloquean el arranque) ─────────────────────────────────────
# MP_PUBLIC_KEY: la Public Key de MP. El backend NO la usa hoy (Checkout Pro
# redirige); quedaría para un brick de pago client-side si algún día se agrega.
MP_PUBLIC_KEY=

# APP_BASE_URL: URL pública de la app (para que QR, links de pedido/regalo y el
# webhook apunten al dominio público y no a localhost). Recomendada en producción.
# En local podés dejarla vacía (usa el host del request). Ej: https://wol.tu-usuario.repl.co
APP_BASE_URL=

# PORT: puerto del server (por defecto 3000).
PORT=3000

# DEMO_MODE: poné 'true' para correr la demo pública (sin credenciales, base en
# memoria, pagos simulados). Dejalo vacío/sin setear para el modo real.
DEMO_MODE=
