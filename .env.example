# Copiá este archivo a .env y completá con tus credenciales.
# (El .env real NUNCA se sube al repo — está en .gitignore.)

# --- Mercado Pago (Checkout Pro) ---
# Se obtienen en: https://www.mercadopago.com.ar/developers → Tus integraciones → Credenciales
# Para testear usá las credenciales de PRUEBA (empiezan con TEST-...).
# Para producción, reemplazá por las de la cuenta del boliche (APP_USR-...).
MP_ACCESS_TOKEN=TEST-xxxxxxxx
MP_PUBLIC_KEY=TEST-xxxxxxxx
MP_WEBHOOK_SECRET=tu_clave_secreta_del_webhook

# --- URL pública de la app ---
# Necesaria para que los QR, links de pedido/regalo y el webhook apunten al dominio
# público (no a localhost). En local podés dejarla vacía (usa el host del request).
# En Replit: poné la URL pública de tu Repl, ej. https://wol.tu-usuario.repl.co
APP_BASE_URL=

# Puerto (opcional, por defecto 3000)
PORT=3000
